<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Chấm tròn đỏ báo chưa đọc -->
    <View
        android:id="@+id/viewChuaDoc"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="#E53935"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Icon loại thông báo -->
    <ImageView
        android:id="@+id/imgIconThongBao"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/tvTieuDeThongBao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toEndOf="@id/imgIconThongBao"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/imgIconThongBao"/>

    <!-- Nội dung -->
    <TextView
        android:id="@+id/tvNoiDungThongBao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:textColor="#555555"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@id/tvTieuDeThongBao"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTieuDeThongBao"/>

    <!-- Thời gian -->
    <TextView
        android:id="@+id/tvThoiGianThongBao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        app:layout_constraintStart_toStartOf="@id/tvTieuDeThongBao"
        app:layout_constraintTop_toBottomOf="@id/tvNoiDungThongBao"/>

</androidx.constraintlayout.widget.ConstraintLayout>