<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- Tiêu đề -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thông tin đặt hàng"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Đường kẻ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp"/>

    <!-- Nút lấy thông tin khách hàng -->
    <Button
        android:id="@+id/btnLayThongTin"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:text="Lấy thông tin người đặt"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <!-- Tên người nhận -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Họ tên người nhận *"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/edtTenNguoiNhan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập họ tên..."
        android:inputType="textPersonName"
        android:padding="12dp"
        android:background="@drawable/bg_edittext"
        android:layout_marginBottom="12dp"/>

    <!-- Số điện thoại -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số điện thoại *"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/edtSdt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập số điện thoại..."
        android:inputType="phone"
        android:padding="12dp"
        android:background="@drawable/bg_edittext"
        android:layout_marginBottom="12dp"/>

    <!-- Địa chỉ giao hàng -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Địa chỉ giao hàng *"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/edtDiaChi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Số nhà, đường, phường, quận, tỉnh/thành phố..."
        android:inputType="textMultiLine"
        android:lines="3"
        android:gravity="top"
        android:padding="12dp"
        android:background="@drawable/bg_edittext"
        android:layout_marginBottom="16dp"/>

    <!-- Đường kẻ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="12dp"/>

    <!-- Tổng tiền -->
    <TextView
        android:id="@+id/tvTongTienDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tổng tiền: 0đ"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E53935"
        android:gravity="end"
        android:layout_marginBottom="16dp"/>

    <!-- 2 nút hành động -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnHuy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Hủy"
            android:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF"
            android:textSize="15sp"/>

        <Button
            android:id="@+id/btnXacNhan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Xác nhận"
            android:backgroundTint="#E53935"
            android:textColor="#FFFFFF"
            android:textSize="15sp"/>
    </LinearLayout>

</LinearLayout>